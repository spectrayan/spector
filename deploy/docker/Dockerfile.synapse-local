# Runtime-only Dockerfile for Synapse (uses pre-built fat JAR from host)
FROM eclipse-temurin:25-jre

LABEL maintainer="Spectrayan <team@spectrayan.com>"
LABEL description="Spector Synapse — Cognitive Memory Server (local build)"

RUN groupadd -r spector && useradd -r -g spector spector && \
    apt-get update && apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy pre-built fat JAR
COPY synapse/spector-synapse/target/spector-synapse-*.jar app.jar

# Data directory
RUN mkdir -p /data && chown -R spector:spector /data /app

USER spector

ENV SPECTOR_PORT=7070 \
    SPECTOR_DATA_DIR=/data \
    SPECTOR_OLLAMA_BASE_URL=http://host.docker.internal:11434 \
    SPECTOR_OLLAMA_MODEL=llama3.2 \
    SPECTOR_OLLAMA_EMBED_MODEL=nomic-embed-text \
    SPECTOR_CORS_ORIGINS=http://localhost:4200 \
    JAVA_OPTS="-XX:+UseZGC -Xmx1g --enable-preview --add-modules=jdk.incubator.vector --enable-native-access=ALL-UNNAMED"

EXPOSE 7070

HEALTHCHECK --interval=10s --timeout=5s --start-period=30s --retries=5 \
    CMD curl -sf http://localhost:7070/actuator/health || exit 1

ENTRYPOINT ["sh", "-c", "exec java $JAVA_OPTS -jar app.jar"]
