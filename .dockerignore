# ──────────── Docker Build Context ────────────
# Exclude files not needed for Docker builds

# Git
.git
.github
.gitignore

# IDE
.idea
.vscode
*.iml

# Node (cortex source not needed — we copy pre-built dist)
**/node_modules
cortex/spector-cortex/.angular
cortex/spector-cortex/src
cortex/spector-cortex/public

# Maven build output (rebuilt in container)
**/target
# Exception: allow pre-built Synapse fat JAR for local deployment
!synapse/spector-synapse/target/spector-synapse-*.jar

# Top-level documentation (not source code)
ACKNOWLEDGMENTS.md
CHANGELOG.md
CODE_OF_CONDUCT.md
CONTRIBUTING.md
LICENSE
NOTICE
SECURITY.md
docs/
RnD/

# Test data & benchmarks
.spector/
.spector-bench/
.spector-bench-bge/
.test-data/
datasets/
embedding-cache/
openclaw/

# Config & scripts
.scratch/
scripts/
.agents/
.gemini/
.kiro/

# OS
.DS_Store
Thumbs.db
*.log

# Docker context noise
*.md
!README.md
.mcp-src
